{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lit! Music Data Schema v2",
  "type": "object",
  "properties": {
    "camp": {
      "$ref": "#/definitions/yearRecord"
    },
    "school": {
      "$ref": "#/definitions/yearRecord"
    },
    "event": {
      "$ref": "#/definitions/yearRecord"
    }
  },
  "required": ["camp", "school", "event"],
  "definitions": {
    "yearRecord": {
      "type": "object",
      "patternProperties": {
        "^([0-9]{4}|.+)$": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "songs"],
            "properties": {
              "name": {
                "type": "string",
                "description": "イベント名"
              },
              "background": {
                "type": "string",
                "pattern": "^$|^\\.\\./\\.\\./res/img/backgrounds/.+\\.webp$",
                "description": "背景画像の相対パス。長辺を1920pxにリサイズし、WebP形式に変換すること"
              },
              "theme": {
                "type": "string",
                "description": "イベントのキャッチコピー"
              },
              "poem": {
                "type": "string",
                "description": "イベントのポエムや説明文"
              },
              "isBefore2024": {
                "type": "boolean",
                "description": "2024年6月25日以前のイベントかどうか。初期値はfalse。backgroundが未設定の場合は定義すること。"
              },
              "songs": {
                "type": "array",
                "description": "楽曲のリスト",
                "items": {
                  "type": "object",
                  "required": [
                    "title",
                    "author",
                    "description",
                    "spotify",
                    "damNumber",
                    "damUrl",
                    "joyNumber",
                    "joyUrl",
                    "lyricsSiteName",
                    "lyricsUrl",
                    "youtubeUrl"
                  ],
                  "properties": {
                    "title": {
                      "type": "string",
                      "description": "曲名"
                    },
                    "author": {
                      "type": "string",
                      "description": "アーティスト名"
                    },
                    "description": {
                      "type": "string",
                      "description": "曲の説明文 (Markdown対応)"
                    },
                    "damNumber": {
                      "type": "string",
                      "pattern": "^$|^[0-9]{4}-[0-9]{2}$",
                      "description": "DAMの選曲番号。1234-56形式(ハイフン含む)。"
                    },
                    "damUrl": {
                      "type": "string",
                      "pattern": "^$|^https://www\\.clubdam\\.com/karaokesearch/songleaf\\.html\\?requestNo=[0-9]{4}-[0-9]{2}$",
                      "description": "DAMの楽曲詳細ページURL。https://www.clubdam.com/karaokesearch/songleaf.html?requestNo=1234-56 形式。"
                    },
                    "joyNumber": {
                      "type": "string",
                      "pattern": "^$|^[0-9]+$",
                      "description": "JOYSOUNDの選曲番号。123456形式(数字のみ)。"
                    },
                    "joyUrl": {
                      "type": "string",
                      "pattern": "^$|^https://www\\.joysound\\.com/web/search/song/[0-9]+$",
                      "description": "JOYSOUNDの楽曲詳細ページURL。https://www.joysound.com/web/search/song/123456 形式。"
                    },
                    "lyricsSiteName": {
                      "type": "string",
                      "description": "歌詞サイトの名前。歌ネット, UtaTen, J-Lyric.net等"
                    },
                    "lyricsUrl": {
                      "type": "string",
                      "description": "歌詞ページのURL。"
                    },
                    "youtubeUrl": {
                      "type": "string",
                      "pattern": "^$|^//youtu\\.be/[a-zA-Z0-9_-]+(?<!\\?si=.+)$",
                      "description": "//youtu.be/xxxxxx 形式。?si=等パラメータは含めない。"
                    },
                    "spotify": {
                      "type": "string",
                      "pattern": "^$|^https://open\\.spotify\\.com/track/[a-zA-Z0-9]+$",
                      "description": "SpotifyのトラックURL。https://open.spotify.com/track/xxxxxx 形式。?si=等パラメータは含めない。"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
